{
  "name": "ayahday",
  "private": true,
  "version": "1.0.0",
  "description": "AyahDay static app; Tailwind builds design tokens to dist/app.css. React/Vite shell deferred.",
  "scripts": {
    "build:css": "NODE_ENV=production postcss ./src/styles/tailwind-entry.css -o ./dist/app.css && node ./scripts/relink-font-assets.cjs",
    "watch:css": "postcss ./src/styles/tailwind-entry.css -o ./dist/app.css --watch",
    "build": "npm run build:css"
  },
  "devDependencies": {
    "@fontsource/noto-nastaliq-urdu": "^5.2.8",
    "@fontsource/noto-sans-arabic": "^5.2.10",
    "autoprefixer": "^10.4.20",
    "cssnano": "^8.0.1",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7"
  }
}
